{
  "name": "localcoder",
  "displayName": "LocalCoder",
  "description": "AI coding agent — chat, tool calls, file edits, and terminal TUI in VS Code",
  "version": "1.0.0",
  "publisher": "joypciu",
  "repository": {
    "type": "git",
    "url": "https://github.com/joypciu/localcoder"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0d0d0d",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "coding",
    "chat",
    "llm",
    "openai",
    "anthropic",
    "localcoder"
  ],
  "activationEvents": [
    "onCommand:localcoder.openChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localcoder-sidebar",
          "title": "LocalCoder",
          "icon": "images/button-dark.svg"
        }
      ]
    },
    "views": {
      "localcoder-sidebar": [
        {
          "id": "localcoder.chatView",
          "name": "LocalCoder",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "localcoder.openChat",
        "title": "Open LocalCoder Chat",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "localcoder.openTerminal",
        "title": "Open LocalCoder Terminal",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "localcoder.openNewTerminal",
        "title": "Open LocalCoder in New Tab",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "localcoder.addFilepathToTerminal",
        "title": "LocalCoder: Insert Active Filepath"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "localcoder.openChat",
          "group": "navigation@1"
        },
        {
          "command": "localcoder.openNewTerminal",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "localcoder.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "localcoder.openTerminal",
        "key": "ctrl+escape",
        "mac": "cmd+escape"
      },
      {
        "command": "localcoder.openNewTerminal",
        "key": "ctrl+shift+escape",
        "mac": "cmd+shift+escape"
      },
      {
        "command": "localcoder.addFilepathToTerminal",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun run check-types && bun run lint && node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run check-types && bun run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0"
  }
}
