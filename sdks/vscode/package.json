{
  "name": "localcoder",
  "displayName": "LocalCoder",
  "description": "AI coding agent — chat, tool calls, file edits, and terminal TUI in VS Code",
  "version": "1.0.0",
  "publisher": "joypciu",
  "repository": {
    "type": "git",
    "url": "https://github.com/joypciu/localcoder"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0d0d0d",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "coding",
    "chat",
    "llm",
    "openai",
    "anthropic",
    "localcoder"
  ],
  "activationEvents": [
    "onView:localcoder.chatView",
    "onCommand:localcoder.openChat",
    "onCommand:localcoder.undoLastTurn",
    "onCommand:localcoder.addSelectionToChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localcoder-sidebar",
          "title": "LocalCoder",
          "icon": "images/button-dark.svg"
        }
      ]
    },
    "views": {
      "localcoder-sidebar": [
        {
          "id": "localcoder.chatView",
          "name": "LocalCoder",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "localcoder.openChat",
        "title": "Open LocalCoder Chat",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "localcoder.setupLlamaCpp",
        "title": "LocalCoder: Set up llama.cpp (GGUF)"
      },
      {
        "command": "localcoder.setLlamaContext",
        "title": "LocalCoder: Set llama.cpp context size"
      },
      {
        "command": "localcoder.connectProvider",
        "title": "LocalCoder: Connect cloud provider (OpenRouter, OpenCode Go…)"
      },
      {
        "command": "localcoder.openTerminal",
        "title": "Open LocalCoder CLI (interactive)",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "localcoder.openNewTerminal",
        "title": "Open LocalCoder CLI in New Tab",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "localcoder.addFilepathToTerminal",
        "title": "LocalCoder: Insert Active Filepath"
      },
      {
        "command": "localcoder.undoLastTurn",
        "title": "LocalCoder: Undo Last Agent Changes"
      },
      {
        "command": "localcoder.addSelectionToChat",
        "title": "LocalCoder: Add Selection to Chat"
      },
      {
        "command": "localcoder.explainSelection",
        "title": "LocalCoder: Explain Selection"
      },
      {
        "command": "localcoder.fixSelection",
        "title": "LocalCoder: Fix Selection"
      },
      {
        "command": "localcoder.editSelection",
        "title": "LocalCoder: Edit Selection"
      },
      {
        "command": "localcoder.commandPalette",
        "title": "LocalCoder: Command Palette"
      },
      {
        "command": "localcoder.acceptDiff",
        "title": "LocalCoder: Accept Change",
        "icon": "$(check)"
      },
      {
        "command": "localcoder.rejectDiff",
        "title": "LocalCoder: Reject Change",
        "icon": "$(discard)"
      },
      {
        "command": "localcoder.acceptAllChanges",
        "title": "LocalCoder: Accept All Pending Changes"
      }
    ],
    "menus": {
      "diffEditor/title": [
        {
          "command": "localcoder.acceptDiff",
          "when": "localcoder.hasPendingDiff",
          "group": "navigation@1"
        },
        {
          "command": "localcoder.rejectDiff",
          "when": "localcoder.hasPendingDiff",
          "group": "navigation@2"
        }
      ],
      "editor/title": [
        {
          "command": "localcoder.openChat",
          "group": "navigation@1"
        },
        {
          "command": "localcoder.openNewTerminal",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "command": "localcoder.explainSelection",
          "group": "localcoder@1",
          "when": "editorHasSelection"
        },
        {
          "command": "localcoder.fixSelection",
          "group": "localcoder@2",
          "when": "editorHasSelection"
        },
        {
          "command": "localcoder.editSelection",
          "group": "localcoder@3",
          "when": "editorHasSelection"
        },
        {
          "command": "localcoder.addSelectionToChat",
          "group": "localcoder@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "localcoder.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "localcoder.openTerminal",
        "key": "ctrl+escape",
        "mac": "cmd+escape"
      },
      {
        "command": "localcoder.openNewTerminal",
        "key": "ctrl+shift+escape",
        "mac": "cmd+shift+escape"
      },
      {
        "command": "localcoder.addFilepathToTerminal",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k"
      },
      {
        "command": "localcoder.undoLastTurn",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u"
      },
      {
        "command": "localcoder.addSelectionToChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "localcoder.commandPalette",
        "key": "ctrl+alt+shift+l",
        "mac": "cmd+alt+shift+l"
      },
      {
        "command": "localcoder.acceptDiff",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y",
        "when": "localcoder.hasPendingDiff"
      },
      {
        "command": "localcoder.rejectDiff",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "localcoder.hasPendingDiff"
      }
    ],
    "configuration": {
      "title": "LocalCoder",
      "properties": {
        "localcoder.packagePath": {
          "type": "string",
          "default": "",
          "description": "Path to packages/localcoder. Empty = auto-detect from extension."
        },
        "localcoder.bunPath": {
          "type": "string",
          "default": "",
          "description": "Path to bun executable."
        },
        "localcoder.defaultAgent": {
          "type": "string",
          "enum": [
            "build",
            "plan"
          ],
          "default": "build",
          "description": "Default agent mode (build = full tools, plan = planning)."
        },
        "localcoder.openDiffOnEdit": {
          "type": "boolean",
          "default": true,
          "description": "Open diff editor when agent edits a file."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun run check-types && bun run lint && bun esbuild.js",
    "watch:esbuild": "bun esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run check-types && bun run lint && bun esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "bun run compile-tests && bunx mocha out/test/suite/**/*.test.js --ui tdd --timeout 120000 --exclude out/test/suite/localcoder-llamacpp.test.js --exclude out/test/suite/extension-llamacpp.test.js",
    "test:llama-e2e": "bun run compile-tests && bun run compile && bunx mocha out/test/suite/localcoder-llamacpp.test.js --ui tdd --timeout 300000 --require src/test/vscode-shim.cjs",
    "test:llama-vscode": "bun run pretest && bun -e \"try{require('fs').rmSync('.vscode-test/user-data',{recursive:true,force:true})}catch(e){}\" && vscode-test --label llama-extension",
    "test:all": "bun run pretest && vscode-test --label default"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0"
  }
}
