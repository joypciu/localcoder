{
  "$schema": "https://localcoder.ai/theme.json",
  "defs": {
    "ncBg": "#0D0D12",
    "ncPanel": "#1A1A24",
    "ncDialog": "#0A0A10",
    "ncPrimary": "#56D6C2",
    "ncPlan": "#CF8EF4",
    "ncAccent": "#89B4FA",
    "ncSuccess": "#82E0AA",
    "ncError": "#E74C5E",
    "ncWarn": "#E0AF68",
    "ncMuted": "#4E4E66",
    "ncText": "#CDD6F4",
    "ncBorder": "#34344A"
  },
  "theme": {
    "primary": {
      "dark": "ncPrimary",
      "light": "ncPrimary"
    },
    "secondary": {
      "dark": "ncAccent",
      "light": "ncAccent"
    },
    "accent": {
      "dark": "ncPlan",
      "light": "ncPlan"
    },
    "error": {
      "dark": "ncError",
      "light": "ncError"
    },
    "warning": {
      "dark": "ncWarn",
      "light": "ncWarn"
    },
    "success": {
      "dark": "ncSuccess",
      "light": "ncSuccess"
    },
    "info": {
      "dark": "ncPrimary",
      "light": "ncPrimary"
    },
    "text": {
      "dark": "ncText",
      "light": "ncBg"
    },
    "textMuted": {
      "dark": "#8B95A7",
      "light": "ncPanel"
    },
    "background": {
      "dark": "ncBg",
      "light": "ncText"
    },
    "backgroundPanel": {
      "dark": "ncPanel",
      "light": "ncPanel"
    },
    "backgroundElement": {
      "dark": "ncDialog",
      "light": "ncText"
    },
    "border": {
      "dark": "ncDialog",
      "light": "ncBorder"
    },
    "borderActive": {
      "dark": "ncBorder",
      "light": "ncDialog"
    },
    "borderSubtle": {
      "dark": "ncDialog",
      "light": "ncBorder"
    },
    "diffAdded": {
      "dark": "ncSuccess",
      "light": "ncSuccess"
    },
    "diffRemoved": {
      "dark": "ncError",
      "light": "ncError"
    },
    "diffContext": {
      "dark": "#8B95A7",
      "light": "ncBorder"
    },
    "diffHunkHeader": {
      "dark": "#8B95A7",
      "light": "ncBorder"
    },
    "diffHighlightAdded": {
      "dark": "ncSuccess",
      "light": "ncSuccess"
    },
    "diffHighlightRemoved": {
      "dark": "ncError",
      "light": "ncError"
    },
    "diffAddedBg": {
      "dark": "#3B4252",
      "light": "#E5E9F0"
    },
    "diffRemovedBg": {
      "dark": "#3B4252",
      "light": "#E5E9F0"
    },
    "diffContextBg": {
      "dark": "ncPanel",
      "light": "ncPanel"
    },
    "diffLineNumber": {
      "dark": "#a9aeb6",
      "light": "textMuted"
    },
    "diffAddedLineNumberBg": {
      "dark": "#3B4252",
      "light": "#E5E9F0"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#3B4252",
      "light": "#E5E9F0"
    },
    "markdownText": {
      "dark": "ncText",
      "light": "ncBg"
    },
    "markdownHeading": {
      "dark": "ncPrimary",
      "light": "ncPrimary"
    },
    "markdownLink": {
      "dark": "ncAccent",
      "light": "ncAccent"
    },
    "markdownLinkText": {
      "dark": "ncAccent",
      "light": "ncAccent"
    },
    "markdownCode": {
      "dark": "ncSuccess",
      "light": "ncSuccess"
    },
    "markdownBlockQuote": {
      "dark": "#8B95A7",
      "light": "ncBorder"
    },
    "markdownEmph": {
      "dark": "ncWarn",
      "light": "ncWarn"
    },
    "markdownStrong": {
      "dark": "ncWarn",
      "light": "ncWarn"
    },
    "markdownHorizontalRule": {
      "dark": "#8B95A7",
      "light": "ncBorder"
    },
    "markdownListItem": {
      "dark": "ncPrimary",
      "light": "ncPrimary"
    },
    "markdownListEnumeration": {
      "dark": "ncAccent",
      "light": "ncAccent"
    },
    "markdownImage": {
      "dark": "ncAccent",
      "light": "ncAccent"
    },
    "markdownImageText": {
      "dark": "ncAccent",
      "light": "ncAccent"
    },
    "markdownCodeBlock": {
      "dark": "ncText",
      "light": "ncBg"
    },
    "syntaxComment": {
      "dark": "#8B95A7",
      "light": "ncBorder"
    },
    "syntaxKeyword": {
      "dark": "ncAccent",
      "light": "ncAccent"
    },
    "syntaxFunction": {
      "dark": "ncPrimary",
      "light": "ncPrimary"
    },
    "syntaxVariable": {
      "dark": "ncAccent",
      "light": "ncAccent"
    },
    "syntaxString": {
      "dark": "ncSuccess",
      "light": "ncSuccess"
    },
    "syntaxNumber": {
      "dark": "ncPlan",
      "light": "ncPlan"
    },
    "syntaxType": {
      "dark": "ncAccent",
      "light": "ncAccent"
    },
    "syntaxOperator": {
      "dark": "ncAccent",
      "light": "ncAccent"
    },
    "syntaxPunctuation": {
      "dark": "ncText",
      "light": "ncBg"
    }
  }
}
