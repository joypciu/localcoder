    "@sentry/solid": "10.55.0",
    "@localcoder-ai/sdk": "workspace:*",
    "@localcoder-ai/ui": "workspace:*",
    "@localcoder-ai/core": "workspace:*",
    "@shikijs/transformers": "4.1.0",
    "@solid-primitives/active-element": "2.1.5",
    "@solid-primitives/audio": "1.4.4",
