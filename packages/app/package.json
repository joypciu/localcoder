    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.14",
    "@types/luxon": "3.7.1",
    "@types/node": "25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "playwright": "1.60.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-icons-spritesheet": "3.0.1",
    "vite-plugin-solid": "2.11.12"
  },
  "dependencies": {
