{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "localcoder",
    "description": "AI-powered development tool",
    "private": true,
    "type": "module",
    "packageManager": "bun@1.3.14",
    "scripts": {
        "dev": "bun --cwd packages/localcoder --conditions=browser ./src/index.ts",
        "dev:desktop": "bun --cwd packages/desktop dev",
        "dev:web": "bun --cwd packages/app dev",
        "dev:console": "ulimit -n 10240 2>/dev/null; bun run --cwd packages/console/app dev",
        "dev:storybook": "bun --cwd packages/storybook storybook",
        "lint": "oxlint",
        "typecheck": "bun turbo typecheck",
        "postinstall": "bun run --cwd packages/localcoder fix-node-pty",
        "prepare": "husky",
        "test": "echo 'do not run tests from root' && exit 1",
        "e2e:smoke": "bun run scripts/e2e/run.ts --tier=smoke",
        "e2e": "bun run scripts/e2e/run.ts --tier=standard",
        "e2e:full": "bun run scripts/e2e/run.ts --tier=full",
        "e2e:windows": "bun run scripts/e2e/run.ts --tier=standard",
        "e2e:cli-desktop": "bun run scripts/e2e/run-cli-desktop.ts",
        "visual-test": "bun run scripts/visual-test/run.ts",
        "visual-test:update": "bun run scripts/visual-test/run.ts --update",
        "build:win-gui": "bun run --cwd packages/localcoder build:win-standalone",
        "build:win-standalone": "bun run --cwd packages/localcoder build:win-standalone",
        "install:cli": "bun run --cwd packages/localcoder install:cli"
    },
    "workspaces": {
        "packages": [
            "packages/*",
            "packages/console/*",
            "packages/sdk/js",
            "packages/slack"
        ],
        "catalog": {
            "@effect/opentelemetry": "4.0.0-beta.74",
            "@effect/platform-node": "4.0.0-beta.74",
            "@npmcli/arborist": "9.7.0",
            "@types/bun": "1.3.14",
            "@types/cross-spawn": "6.0.6",
            "@octokit/rest": "22.0.1",
            "@hono/zod-validator": "0.8.0",
            "@opentui/core": "0.3.0",
            "@opentui/solid": "0.3.0",
            "ulid": "3.0.2",
            "@kobalte/core": "0.13.11",
            "@types/luxon": "3.7.1",
            "@types/node": "25.9.1",
            "@types/semver": "7.7.1",
            "@tsconfig/node22": "22.0.5",
            "@tsconfig/bun": "1.0.10",
            "@cloudflare/workers-types": "4.20260530.1",
            "@openauthjs/openauth": "0.4.3",
            "@pierre/diffs": "1.2.4",
            "opentui-spinner": "0.0.6",
            "@solid-primitives/storage": "4.3.4",
            "@tailwindcss/vite": "4.3.0",
            "diff": "9.0.0",
            "dompurify": "3.4.7",
            "drizzle-kit": "1.0.0-beta.9-e89174b",
            "drizzle-orm": "1.0.0-beta.9-e89174b",
            "effect": "4.0.0-beta.74",
            "ai": "6.0.193",
            "cross-spawn": "7.0.6",
            "hono": "4.12.23",
            "hono-openapi": "1.3.0",
            "fuzzysort": "3.1.0",
            "luxon": "3.7.2",
            "marked": "18.0.4",
            "marked-shiki": "1.2.1",
            "remend": "1.3.0",
            "@playwright/test": "1.60.0",
            "semver": "7.8.1",
            "typescript": "6.0.3",
            "@typescript/native-preview": "7.0.0-dev.20260527.2",
            "zod": "4.4.3",
            "remeda": "2.37.0",
            "shiki": "4.1.0",
            "solid-list": "0.3.0",
            "tailwindcss": "4.3.0",
            "virtua": "0.49.1",
            "vite": "8.0.14",
            "@solidjs/meta": "0.29.4",
            "@solidjs/router": "0.16.1",
            "@solidjs/start": "https://pkg.pr.new/@solidjs/start@dfb2020",
            "@sentry/solid": "10.55.0",
            "@sentry/vite-plugin": "5.3.0",
            "solid-js": "1.9.13",
            "vite-plugin-solid": "2.11.12",
            "@lydell/node-pty": "1.2.0-beta.12"
        }
    },
    "devDependencies": {
        "@actions/artifact": "6.2.1",
        "@tsconfig/bun": "1.0.10",
        "@types/mime-types": "3.0.1",
        "@typescript/native-preview": "7.0.0-dev.20260527.2",
        "glob": "13.0.6",
        "husky": "9.1.7",
        "oxlint": "1.67.0",
        "oxlint-tsgolint": "0.23.0",
        "prettier": "3.8.3",
        "semver": "7.8.1",
        "sst": "4.15.2",
        "turbo": "2.9.16"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "3.1057.0",
        "@localcoder-ai/plugin": "workspace:*",
        "@localcoder-ai/script": "workspace:*",
        "@localcoder-ai/sdk": "workspace:*",
        "heap-snapshot-toolkit": "1.1.3",
        "typescript": "6.0.3"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/anomalyco/localcoder"
    },
    "license": "MIT",
    "prettier": {
        "semi": false,
        "printWidth": 120
    },
    "trustedDependencies": [
        "esbuild",
        "node-pty",
        "protobufjs",
        "tree-sitter",
        "tree-sitter-bash",
        "tree-sitter-powershell",
        "web-tree-sitter",
        "electron"
    ],
    "overrides": {
        "@types/bun": "catalog:",
        "@types/node": "catalog:",
        "@babel/core": "7.28.4",
        "@babel/traverse": "7.28.4",
        "debug": "4.3.7"
    },
    "patchedDependencies": {
        "@npmcli/agent@4.0.0": "patches/@npmcli%2Fagent@4.0.0.patch",
        "@standard-community/standard-openapi@0.2.9": "patches/@standard-community%2Fstandard-openapi@0.2.9.patch",
        "solid-js@1.9.13": "patches/solid-js@1.9.10.patch"
    }
}
